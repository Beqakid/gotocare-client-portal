{
  "name": "carehia-client-portal",
  "version": "2.0.0",
  "private": true,
  "description": "Carehia Client Portal — React PWA",
  "scripts": {
    "build": "npx esbuild app.tsx --bundle --splitting --format=esm --outdir=dist --platform=browser --target=es2020 --loader:.tsx=tsx --loader:.ts=tsx --minify",
    "dev": "npx esbuild app.tsx --bundle --splitting --format=esm --outdir=dist --platform=browser --target=es2020 --loader:.tsx=tsx --loader:.ts=tsx --watch"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
